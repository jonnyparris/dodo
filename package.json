{
  "name": "dodo",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev -c wrangler.dev.jsonc",
    "deploy": "COMMIT=$(git rev-parse --short HEAD 2>/dev/null || echo 'unknown') && echo \"{\\\"commit\\\":\\\"$COMMIT\\\"}\" > public/version.json && wrangler deploy --var DODO_COMMIT:$COMMIT",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "types": "wrangler types"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@cloudflare/codemode": "^0.3.2",
    "@cloudflare/shell": "^0.3.0",
    "@cloudflare/think": "^0.1.1",
    "@hono/capnweb": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "agents": "^0.8.7",
    "ai": "^6.0.142",
    "capnweb": "^0.6.1",
    "hono": "^4.12.9",
    "jose": "^6.1.3",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.5",
    "@cloudflare/workers-types": "^4.20260207.0",
    "@types/node": "^24.5.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
